{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake configure (debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "clang-debug"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "cmake configure (release)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "clang-release"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "build (debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "out/build/clang-debug"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "build (release)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "out/build/clang-release"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "build (debug) with configure",
      "dependsOn": ["cmake configure (debug)", "build (debug)"],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      "label": "run tests",
      "type": "shell",
      "command": "ctest",
      "args": ["--test-dir", "out/build/clang-debug", "--output-on-failure"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$gcc"]
    }
  ]
}
