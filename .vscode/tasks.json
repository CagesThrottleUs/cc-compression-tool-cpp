{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake configure",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "clang-debug"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "clang-debug"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "build (debug)",
      "dependsOn": ["cmake configure", "build"],
      "dependsOrder": "sequence",
      "group": "build"
    }
  ]
}
